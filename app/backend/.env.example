# Spring Boot monolith
SERVER_PORT=8080
MYSQL_DSN=jdbc:mysql://127.0.0.1:3306/industrial_fault_tree_ai?useUnicode=true&characterEncoding=utf8&serverTimezone=Asia/Shanghai&allowPublicKeyRetrieval=true&useSSL=false
MYSQL_USER=root
MYSQL_PASSWORD=change-me

# AI model and Redis state/event streams
DASHSCOPE_API_KEY=
AI_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode
AI_MODEL=qwen3.7-max
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_USERNAME=
REDIS_PASSWORD=
REDIS_DB=0

# Document storage and search
STATIC_ROOT=../static
DOCUMENT_ROOT=../static/document
FILE_BIG_THRESHOLD_BYTES=12000
FILE_CHUNK_MIN_SIZE=200
FILE_CHUNK_MAX_SIZE=400
ELASTICSEARCH_URL=http://127.0.0.1:9200
ELASTICSEARCH_USERNAME=
ELASTICSEARCH_PASSWORD=
MILVUS_URL=http://127.0.0.1:19530
MILVUS_USERNAME=
MILVUS_PASSWORD=
EMBEDDING_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
EMBEDDING_MODEL=text-embedding-v1
EMBEDDING_DIMENSIONS=1536

# AI work pool and stream behavior
AI_WORKPOOL_MIN_WORKERS=1
AI_WORKPOOL_MAX_WORKERS=4
AI_WORKPOOL_QUEUE_SIZE=128
AI_WORKPOOL_SCALE_UP_THRESHOLD=4
AI_WORKPOOL_SCALE_DOWN_THRESHOLD=0
AI_WORKPOOL_IDLE_TIMEOUT_SECONDS=30
AI_TERMINAL_TTL_SECONDS=10
AI_CONTROL_BLOCK_MS=30000
AI_STREAM_MAX_BLOCK_MS=30000
AI_STREAM_MAX_READ_COUNT=100
AI_CONTROL_READ_COUNT=10
