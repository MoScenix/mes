<view class="page-shell auth-page">
  <view class="brand-mark">MES</view>
  <view class="auth-copy">
    <text class="auth-title">MES 用户登录</text>
    <text class="auth-subtitle">高效生产管理系统</text>
  </view>
  <view class="surface auth-form">
    <label class="form-field">
      <text class="field-label">账号</text>
      <input class="field-input" placeholder="请输入账号" value="{{userAccount}}" bindinput="onAccount" />
    </label>
    <label class="form-field">
      <text class="field-label">密码</text>
      <input class="field-input" password placeholder="请输入 8 位以上密码" value="{{userPassword}}" bindinput="onPassword" />
    </label>
    <button class="primary-button" loading="{{submitting}}" bindtap="submit">登录</button>
    <button class="link-button" bindtap="goRegister">没有账号？去注册</button>
  </view>
</view>
