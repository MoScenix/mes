.scan-page { padding-top: 70rpx; }
.scan-copy { display: flex; flex-direction: column; align-items: center; text-align: center; margin-bottom: 48rpx; }
.scan-title { font-size: 48rpx; font-weight: 700; line-height: 1.2; }
.scan-subtitle { width: 88%; margin-top: 16rpx; color: #94a3b8; font-size: 25rpx; line-height: 1.55; }
.scan-trigger { min-height: 420rpx; padding: 58rpx 30rpx; display: flex; flex-direction: column; align-items: center; justify-content: center; background: #fff; border: 2rpx dashed #cbd5e1; border-radius: 28rpx; }
.large-scan-icon { position: relative; width: 126rpx; height: 126rpx; margin-bottom: 34rpx; }
.large-scan-icon .corner { position: absolute; width: 38rpx; height: 38rpx; border-color: #2563eb; border-style: solid; }
.large-scan-icon .c1 { top: 0; left: 0; border-width: 8rpx 0 0 8rpx; }
.large-scan-icon .c2 { top: 0; right: 0; border-width: 8rpx 8rpx 0 0; }
.large-scan-icon .c3 { bottom: 0; left: 0; border-width: 0 0 8rpx 8rpx; }
.large-scan-icon .c4 { right: 0; bottom: 0; border-width: 0 8rpx 8rpx 0; }
.large-scan-icon .scan-line { position: absolute; left: 18rpx; right: 18rpx; top: 60rpx; height: 5rpx; border-radius: 3rpx; background: #2563eb; }
.scan-button-title { color: #1e293b; font-size: 32rpx; font-weight: 650; }
.scan-button-help { margin-top: 12rpx; color: #94a3b8; font-size: 23rpx; }
.context-panel, .detail-panel, .unit-panel { margin-bottom: 26rpx; padding: 30rpx; }
.context-top, .detail-head { display: flex; justify-content: space-between; align-items: center; }
.context-label, .detail-kind, .unit-label { color: #64748b; font-size: 24rpx; }
.reset-button { margin: 0; padding: 0 12rpx; background: transparent; color: #2563eb; font-size: 24rpx; line-height: 1.5; }
.context-title, .unit-title, .detail-name { display: block; margin-top: 16rpx; font-size: 32rpx; font-weight: 650; }
.context-progress { display: block; margin-top: 12rpx; color: #2563eb; font-size: 25rpx; }
.detail-id { color: #94a3b8; font-size: 25rpx; }
.detail-row { margin-top: 24rpx; padding-top: 22rpx; display: flex; justify-content: space-between; color: #64748b; font-size: 25rpx; border-top: 1rpx solid #eef2f7; }
.quality-actions { display: grid; grid-template-columns: 1fr 1fr; gap: 18rpx; margin-top: 30rpx; }
.result-message { margin-top: 24rpx; padding: 22rpx 26rpx; border-radius: 16rpx; background: #ecfdf5; color: #047857; font-size: 25rpx; text-align: center; }
