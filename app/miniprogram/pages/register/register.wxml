<view class="page-shell auth-page">
  <view class="auth-copy">
    <text class="auth-title">MES 用户注册</text>
    <text class="auth-subtitle">加入高效生产管理</text>
  </view>
  <view class="surface auth-form">
    <label class="form-field"><text class="field-label">账号</text><input class="field-input" placeholder="请设置登录账号" value="{{userAccount}}" bindinput="onAccount" /></label>
    <label class="form-field"><text class="field-label">密码</text><input class="field-input" password placeholder="请输入 8 位以上密码" value="{{userPassword}}" bindinput="onPassword" /></label>
    <label class="form-field"><text class="field-label">确认密码</text><input class="field-input" password placeholder="请再次输入密码" value="{{checkPassword}}" bindinput="onCheckPassword" /></label>
    <button class="primary-button" loading="{{submitting}}" bindtap="submit">注册</button>
    <button class="link-button" bindtap="goLogin">已有账号？去登录</button>
  </view>
</view>
