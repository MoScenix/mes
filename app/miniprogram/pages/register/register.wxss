.auth-page { display: flex; flex-direction: column; justify-content: center; }
.auth-copy { display: flex; flex-direction: column; align-items: center; margin-bottom: 42rpx; }
.auth-title { font-size: 44rpx; line-height: 1.25; font-weight: 700; }
.auth-subtitle { margin-top: 12rpx; color: #94a3b8; font-size: 26rpx; }
.auth-form { padding: 40rpx 36rpx 30rpx; }
.form-field { display: block; margin-bottom: 28rpx; }
.link-button { margin-top: 20rpx; background: transparent; color: #2563eb; font-size: 26rpx; }
